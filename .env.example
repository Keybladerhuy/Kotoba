# ============================================================
# Environment config for generate-exercises.js
# Copy this file to .env and fill in your keys.
# ============================================================

# --- LLM API Keys (set at least one) ---

# Google AI Studio key — for Gemini Flash (free tier: 1500 req/day)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic key — for Claude Haiku (paid, ~$0.001/exercise)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Ollama (local LLM, no key needed) ---

# Model to use with Ollama (default: qwen2.5:7b)
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_URL=http://localhost:11434

# --- Defaults (override with CLI flags) ---

# JLPT level: N1, N2, N3, N4, or N5
# EXERCISE_LEVEL=N1

# Number of exercises per run
# EXERCISE_COUNT=1

# LLM provider: gemini, haiku, or ollama
# EXERCISE_PROVIDER=gemini
